# ── Python ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.pytest_cache/
.coverage
htmlcov/

# ── Virtual environments ────────────────────────────────────────────
.venv/
venv/
env/
ENV/

