# ── ResolutionMessenger — environment template ──────────────────────
# Copy this file to `.env` (in the package folder) and fill in the values
# for your deployment. ALL of the values below are optional unless noted;
# defaults in config.py let the project import + tests run with no .env at all.

# ── Required for any live run ───────────────────────────────────────
# Monday.com API token (or a generic BOARD_API_TOKEN if you fork to a
# different provider). Used by board_client.py for every GraphQL call.
BOARD_API_TOKEN=

# ── Outlook send identity ───────────────────────────────────────────
# The "from" address shown on outgoing alerts. The Outlook desktop COM
# integration uses whatever profile is signed in — this just labels the
# from-line and is also used as a last-resort fallback recipient.
EMAIL_FROM=

# Last-resort recipient if salesperson lookup fails AND
# NOTIFY_FALLBACK_EMAIL is unset.
EMAIL_TO=

# Preferred fallback if name-derivation fails.
NOTIFY_FALLBACK_EMAIL=

# Optional always-BCC list (comma-separated).
NOTIFY_BCC=

# ── Board layout ────────────────────────────────────────────────────
# Identifiers for the Monday.com board you're integrating with. Replace
# the defaults in config.py with your board's actual values OR set them
# here to keep config.py clean.
BOARD_API_URL=https://api.monday.com/v2
BOARD_ID=
COL_STATUS=status__1
COL_ALLOCATE=status9__1
COL_PAID_IN_FULL=single_select62__1
COL_SALESPERSON=dup__of_people__1
COL_DELIVERY=date7__1

# ── Status label values ─────────────────────────────────────────────
# Override only if your board uses different labels.
STATUS_NEEDS_ATTENTION=NEEDS ATTENTION
STATUS_SCHEDULED=SCHEDULED
ALLOCATE_PIECE_ON_PO=PIECE(S) ON PO
ALLOCATE_LOW_STOCK=PIECE(S) LOW STOCK
PAID_IN_FULL_NO=NO
PAID_IN_FULL_AR_ACCOUNT=AR ACCOUNT

# ── Reply-button routing ────────────────────────────────────────────
# When a recipient clicks REPLY TO OPERATIONS in the alert, the mailto
# pre-fills these addresses.
REPLY_TO_ADDRESS=operations@example.com
REPLY_CC_ADDRESSES=lead1@example.com,lead2@example.com

# ── Template-specific CC lists ──────────────────────────────────────
# Different alert templates loop in different stakeholders.
UNPAID_TEMPLATE_CC=accounting@example.com,frontdesk@example.com
SUPPLY_TEMPLATE_CC=purchasing1@example.com,purchasing2@example.com

# ── Recipient derivation domain ─────────────────────────────────────
# Used by `email_from_name()`: "Alex Carter" -> "alexc@<domain>".
RECIPIENT_DOMAIN=example.com

# ── Tracking marker ─────────────────────────────────────────────────
# The short tag embedded in alert subjects (e.g., "[RM:27341]") that the
# inbox scanner uses to detect reply emails.
TRACKING_MARKER_PREFIX=RM

# ── Schedule / staleness tuning ─────────────────────────────────────
OPS_TZ=America/Los_Angeles
OPS_HOLIDAYS=2026-01-01,2026-07-04,2026-12-25
STALE_REPORT_WINDOW_DAYS=30
ACTIVITY_FRESHNESS_HOURS=48

# ── Storage ─────────────────────────────────────────────────────────
# Override to keep the SQLite DB outside the package folder.
ISSUES_DB_PATH=

# ── Misc ────────────────────────────────────────────────────────────
# If you keep your real .env in a non-default location, set this in your
# shell to point ResolutionMessenger at it.
# RM_ENV_PATH=/secrets/path/to/.env
